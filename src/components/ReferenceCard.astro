---
interface Props {
  title: string;
  subtitle?: string;
  category?: string;
  badge?: string;
  href?: string;
}

const { title, subtitle, category, badge, href } = Astro.props;
---

<details class="ref-card" data-category={category}>
  <summary>
    <span class="ref-card-title">{title}</span>
    {badge && <span class="badge">{badge}</span>}
  </summary>
  {subtitle && <p class="subtitle">{subtitle}</p>}
  {href && (
    <p class="deep-dive-link">
      <a href={href}>View full deep-dive →</a>
    </p>
  )}
  <div class="detail-content">
    <slot />
  </div>
</details>
